---
import BaseLayout from '../components/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import MagnaWaveBadge from '../components/MagnaWaveBadge.astro';
import { SITE, withBase } from '../config';

const title = 'Book a Session | Happy Horses RI';
const description =
  'Request a mobile PEMF session for your horse or dog anywhere in Rhode Island or nearby Massachusetts. Send a few details and Bree will get right back to you.';

const inputClass =
  'mt-1.5 block w-full rounded-xl border border-sage-200 bg-cream px-4 py-3 text-charcoal placeholder:text-charcoal-600/60 focus:border-pine focus:outline-none focus:ring-2 focus:ring-pine/30';
const labelClass = 'block text-sm font-semibold text-pine';
---

<BaseLayout title={title} description={description}>
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 py-12 text-center lg:pt-16">
      <Badge>Now Accepting New Clients</Badge>
      <h1 class="mt-5 font-display text-4xl font-semibold text-pine sm:text-5xl">Book a Session</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-charcoal-600">
        Tell Bree a little about your animal and how to reach you. She’ll get back to you soon to
        find a time that works.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-10 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr]">
      <!-- FORM -->
      <div class="rounded-3xl border border-sage-200 bg-white p-6 shadow-sm sm:p-9">
        <form action="https://api.web3forms.com/submit" method="POST" id="booking-form">
          <!-- Web3Forms configuration -->
          <input type="hidden" name="access_key" value={SITE.web3formsKey} />
          <input type="hidden" name="subject" value={`New booking request | ${SITE.name}`} />
          <input type="hidden" name="from_name" value={`${SITE.name} website`} />
          <!-- Redirect is set by JS below to work on any domain; this is a fallback. -->
          <input type="hidden" name="redirect" value={`${SITE.url}/thanks`} />
          <!-- Honeypot spam trap (real people never see or fill this) -->
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label for="name" class={labelClass}>Your name <span class="text-saddle">*</span></label>
              <input id="name" name="name" type="text" required autocomplete="name" class={inputClass} />
            </div>

            <div>
              <label for="email" class={labelClass}>Email <span class="text-saddle">*</span></label>
              <input id="email" name="email" type="email" required autocomplete="email" class={inputClass} />
            </div>

            <div>
              <label for="phone" class={labelClass}>Phone <span class="text-saddle">*</span></label>
              <input id="phone" name="phone" type="tel" required autocomplete="tel" class={inputClass} />
            </div>

            <div>
              <label for="animal_type" class={labelClass}>Animal type <span class="text-saddle">*</span></label>
              <select id="animal_type" name="animal_type" required class={inputClass}>
                <option value="Horse">Horse</option>
                <option value="Dog">Dog</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div>
              <label for="animal_name" class={labelClass}>Animal’s name</label>
              <input id="animal_name" name="animal_name" type="text" class={inputClass} />
            </div>

            <div class="sm:col-span-2">
              <label for="location" class={labelClass}>Barn or town <span class="text-saddle">*</span></label>
              <input
                id="location"
                name="location"
                type="text"
                required
                placeholder="e.g. Sunny Acres Farm, Warwick RI"
                class={inputClass}
              />
            </div>

            <div class="sm:col-span-2">
              <label for="contact_method" class={labelClass}>Preferred contact method</label>
              <select id="contact_method" name="contact_method" class={inputClass}>
                <option value="Email">Email</option>
                <option value="Phone call">Phone call</option>
                <option value="Text message">Text message</option>
              </select>
            </div>

            <div class="sm:col-span-2">
              <label for="message" class={labelClass}>
                Anything else? <span class="font-normal text-charcoal-600">(goals, schedule, questions)</span>
              </label>
              <textarea id="message" name="message" rows="5" class={inputClass}></textarea>
            </div>
          </div>

          <button
            type="submit"
            class="mt-7 inline-flex w-full items-center justify-center rounded-full bg-pine px-8 py-4 text-base font-semibold text-cream transition-colors hover:bg-saddle sm:w-auto"
          >
            Send booking request
          </button>
          <p class="mt-4 text-xs text-charcoal-600">
            Fields marked <span class="text-saddle">*</span> are required. Your details go straight to
            Bree and are never shared or sold.
          </p>
        </form>
      </div>

      <!-- DIRECT CONTACT -->
      <aside class="space-y-6">
        <div class="rounded-3xl bg-pine p-7 text-cream">
          <h2 class="font-display text-2xl font-semibold text-cream">Prefer to reach out directly?</h2>
          <p class="mt-3 text-sm leading-relaxed text-cream/80">
            {
              SITE.phoneHref
                ? 'Call or text, or send an email — whatever’s easiest for you.'
                : 'Direct phone and email are coming soon — for now, the booking form is the best way to reach Bree.'
            }
          </p>
          <div class="mt-6 space-y-4">
            <a href={SITE.phoneHref || undefined} class="flex items-center gap-3 text-cream transition-colors hover:text-saddle">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-cream/15">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </span>
              <span>
                <span class="block text-xs uppercase tracking-wide text-cream/60">Call or text</span>
                <span class="font-semibold">{SITE.phone}</span>
              </span>
            </a>
            <a href={SITE.emailHref || undefined} class="flex items-center gap-3 text-cream transition-colors hover:text-saddle">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-cream/15">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2" /><polyline points="22,6 12,13 2,6" />
                </svg>
              </span>
              <span class="min-w-0">
                <span class="block text-xs uppercase tracking-wide text-cream/60">Email</span>
                <span class="break-all font-semibold">{SITE.email}</span>
              </span>
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-sage-200 bg-white p-7">
          <div class="flex items-center gap-4">
            <MagnaWaveBadge size={64} class="shrink-0" />
            <div>
              <p class="font-display text-lg font-semibold text-pine">Serving RI &amp; nearby MA</p>
              <p class="mt-1 text-sm text-charcoal-600">{SITE.serviceArea}</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ thanksPath: withBase('/thanks') }}>
    // Make the post-submit redirect land on this exact deployment's /thanks page,
    // whatever domain (and base path) the site is served from.
    (function () {
      var form = document.getElementById('booking-form');
      if (!form) return;
      var redirect = form.querySelector('input[name="redirect"]');
      if (redirect) redirect.value = window.location.origin + thanksPath;
    })();
  </script>
</BaseLayout>
