---
// A subtle PEMF pulse-wave divider between sections.
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---

<div class:list={['flex items-center justify-center gap-3 py-4', cls]} aria-hidden="true">
  <span class="h-px w-16 bg-sage-200 sm:w-28"></span>
  <svg width="132" height="22" viewBox="0 0 132 22" fill="none" class="text-saddle">
    <path
      d="M0 11 H44 l5 -8 l6 16 l7 -18 l6 18 l5 -8 H132"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
  <span class="h-px w-16 bg-sage-200 sm:w-28"></span>
</div>
