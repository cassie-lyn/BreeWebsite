---
import { SITE, NAV_LINKS, withBase } from '../config';

const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const path = norm(Astro.url.pathname);
const home = norm(withBase('/'));
const isActive = (href: string) => {
  const target = norm(href);
  return target === home ? path === home : path === target || path.startsWith(target + '/');
};
---

<header class="sticky top-0 z-40 border-b border-sage-200 bg-cream/95 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5" aria-label="Main">
    <a href={withBase('/')} class="flex items-center gap-2.5 font-display text-xl font-semibold text-pine">
      <img src={withBase('/favicon.svg')} alt="" width="34" height="34" class="h-8 w-8" />
      <span>{SITE.name}</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        NAV_LINKS.map((link) =>
          link.button ? (
            <li>
              <a
                href={link.href}
                class="ml-2 inline-flex items-center rounded-full bg-pine px-5 py-2.5 text-sm font-semibold text-cream transition-colors hover:bg-saddle"
              >
                {link.label}
              </a>
            </li>
          ) : (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class:list={[
                  'rounded-full px-4 py-2 text-sm font-semibold transition-colors hover:text-pine',
                  isActive(link.href) ? 'text-pine' : 'text-charcoal-600',
                ]}
              >
                {link.label}
              </a>
            </li>
          ),
        )
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-lg p-2 text-pine md:hidden"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Toggle menu"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-menu" class="hidden border-t border-sage-200 bg-cream md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-5 py-3">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'block rounded-lg px-3 py-2.5 text-base font-semibold',
                link.button
                  ? 'mt-1 bg-pine text-center text-cream'
                  : isActive(link.href)
                    ? 'bg-sage-100 text-pine'
                    : 'text-charcoal',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
  };
  const isOpen = () => !menu?.classList.contains('hidden');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setOpen(!isOpen());
  });

  // Tapping anywhere outside the open menu closes it
  document.addEventListener('click', (e) => {
    if (!isOpen()) return;
    const target = e.target as Node;
    if (!menu?.contains(target) && !toggle?.contains(target)) setOpen(false);
  });

  // Escape closes it too (nice for keyboard users)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen()) setOpen(false);
  });
</script>
