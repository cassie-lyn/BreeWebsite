---
/**
 * The official "MagnaWave Certified" seal (yellow circle, blue text).
 * Source file: src/assets/magnawave-seal.png (180x180 original, so avoid
 * rendering larger than ~180px).
 */
import { Image } from 'astro:assets';
import seal from '../assets/magnawave-seal.png';

interface Props {
  size?: number;
  class?: string;
}
const { size = 120, class: cls = '' } = Astro.props;
---

<Image
  src={seal}
  alt="MagnaWave Certified seal"
  width={size}
  height={size}
  class:list={[cls]}
/>
