---
interface Props {
  author: string;
  location?: string;
}
const { author, location } = Astro.props;
---

<figure class="flex h-full flex-col rounded-2xl border border-sage-200 bg-white p-7 shadow-sm">
  <svg
    width="34"
    height="34"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="text-sage"
    aria-hidden="true"
  >
    <path
      d="M9.5 8C7 8 5 10 5 12.5S7 17 9.5 17c.3 0 .6 0 .9-.1C9.6 18.7 8 20 6 20.5c-.4.1-.6.5-.5.9.1.3.4.6.8.6h.2c3.6-.9 6-4 6-8V12c0-2.2-1.8-4-4-4zm9 0c-2.5 0-4.5 2-4.5 4.5S16 17 18.5 17c.3 0 .6 0 .9-.1-.8 1.8-2.4 3.1-4.4 3.6-.4.1-.6.5-.5.9.1.3.4.6.8.6h.2c3.6-.9 6-4 6-8V12c0-2.2-1.8-4-4-4z"
    ></path>
  </svg>
  <blockquote class="mt-4 flex-1 text-lg leading-relaxed text-charcoal">
    <slot />
  </blockquote>
  <figcaption class="mt-6 border-t border-sage-100 pt-4">
    <span class="font-semibold text-pine">{author}</span>
    {location && <span class="block text-sm text-charcoal-600">{location}</span>}
  </figcaption>
</figure>
