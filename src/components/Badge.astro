---
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
}
const { variant = 'light', class: cls = '' } = Astro.props;

const styles = {
  light: 'bg-sage-100 text-pine ring-1 ring-inset ring-sage-200',
  dark: 'bg-cream/15 text-cream ring-1 ring-inset ring-cream/30',
};
---

<span
  class:list={[
    'inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-semibold',
    styles[variant],
    cls,
  ]}
>
  <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-saddle opacity-70"
    ></span>
    <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-saddle"></span>
  </span>
  <slot>Now Accepting New Clients</slot>
</span>
