---
interface Props {
  title: string;
  price?: string;
  priceNote?: string;
  featured?: boolean;
  features?: string[];
  /** Small muted note under the card body (e.g. a TODO / pricing caveat). */
  note?: string;
  class?: string;
}
const {
  title,
  price,
  priceNote,
  featured = false,
  features = [],
  note,
  class: cls = '',
} = Astro.props;
---

<div
  class:list={[
    'relative flex h-full flex-col rounded-2xl p-7 shadow-sm',
    featured
      ? 'border-2 border-pine bg-white'
      : 'border border-sage-200 bg-white',
    cls,
  ]}
>
  {
    featured && (
      <span class="absolute -top-3 left-7 rounded-full bg-pine px-3 py-1 text-xs font-bold uppercase tracking-wide text-cream">
        Most popular
      </span>
    )
  }
  <h3 class="font-display text-2xl font-semibold text-pine">{title}</h3>

  {
    price && (
      <p class="mt-3 flex items-baseline gap-1.5">
        <span class="font-display text-4xl font-bold text-charcoal">{price}</span>
        {priceNote && <span class="text-sm text-charcoal-600">{priceNote}</span>}
      </p>
    )
  }

  <div class="mt-4 text-charcoal-600">
    <slot />
  </div>

  {
    features.length > 0 && (
      <ul class="mt-5 space-y-2.5 text-sm text-charcoal">
        {features.map((f) => (
          <li class="flex items-start gap-2.5">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="mt-0.5 shrink-0 text-saddle"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    )
  }

  {note && <p class="mt-5 border-t border-sage-100 pt-4 text-xs italic text-charcoal-600">{note}</p>}
</div>
