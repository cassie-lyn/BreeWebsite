---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, align = 'left', class: cls = '' } = Astro.props;
---

<div class:list={[align === 'center' ? 'mx-auto max-w-2xl text-center' : 'max-w-2xl', cls]}>
  {
    eyebrow && (
      <p class="text-sm font-bold uppercase tracking-widest text-saddle">{eyebrow}</p>
    )
  }
  <h2 class="mt-2 font-display text-3xl font-semibold text-pine sm:text-4xl">{title}</h2>
  <slot />
</div>
