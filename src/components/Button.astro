---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'cream';
  size?: 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: cls = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-colors';
const sizes = {
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};
const variants = {
  primary: 'bg-pine text-cream hover:bg-saddle',
  secondary: 'bg-saddle text-cream hover:bg-saddle-700',
  outline: 'border-2 border-pine text-pine hover:bg-pine hover:text-cream',
  cream: 'bg-cream text-pine hover:bg-sage-100',
};
---

<a href={href} class:list={[base, sizes[size], variants[variant], cls]}>
  <slot />
</a>
