---
import { SITE, NAV_LINKS } from '../config';
const year = new Date().getFullYear();
---

<footer class="mt-auto bg-pine text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <p class="font-display text-2xl font-semibold text-cream">{SITE.name}</p>
      <p class="mt-3 text-sm leading-relaxed text-sage-100">
        {SITE.practitioner} · MagnaWave-certified PEMF practitioner. Mobile wellness therapy for
        horses and dogs.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-sage">Explore</h2>
      <ul class="mt-4 space-y-2.5 text-sm">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-cream/90 transition-colors hover:text-saddle">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-sage">Get in touch</h2>
      <ul class="mt-4 space-y-2.5 text-sm">
        <li>
          {
            SITE.phoneHref ? (
              <a href={SITE.phoneHref} class="text-cream/90 transition-colors hover:text-saddle">
                {SITE.phone}
              </a>
            ) : (
              <span class="text-cream/90">{SITE.phone}</span>
            )
          }
        </li>
        <li>
          {
            SITE.emailHref ? (
              <a href={SITE.emailHref} class="break-all text-cream/90 transition-colors hover:text-saddle">
                {SITE.email}
              </a>
            ) : (
              <span class="break-all text-cream/90">{SITE.email}</span>
            )
          }
        </li>
        <li class="pt-1 text-cream/70">Based in {SITE.baseCity}</li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wider text-sage">Service area</h2>
      <p class="mt-4 text-sm leading-relaxed text-cream/80">{SITE.serviceArea}</p>
    </div>
  </div>

  <div class="border-t border-cream/15">
    <div class="mx-auto max-w-6xl px-5 py-6">
      <p class="text-xs leading-relaxed text-cream/60">
        <strong class="font-semibold text-cream/80">Wellness note:</strong> PEMF is a complementary
        wellness service and is not a substitute for veterinary care, diagnosis, or treatment. Always
        consult your veterinarian for medical concerns.
      </p>
      <p class="mt-4 text-xs text-cream/50">
        © {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
